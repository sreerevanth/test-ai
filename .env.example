# TestAI Environment Variables
# Copy this file to .env and fill in with your actual values

# Frontend
VITE_APP_NAME=TestAI
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:3001

# Backend
NODE_ENV=development
PORT=3001

# API Keys (if using real AI services)
VITE_CLAUDE_API_KEY=your_claude_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Database (for future use)
DATABASE_URL=mongodb://localhost:27017/testai
DATABASE_USER=admin
DATABASE_PASSWORD=password

# Authentication (for future use)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# OAuth (for future use)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email Service (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Analytics
VITE_GA_ID=your_google_analytics_id
VITE_SENTRY_DSN=your_sentry_dsn

# Feature Flags
VITE_ENABLE_REAL_AI=false
VITE_ENABLE_DATABASE=false
VITE_ENABLE_ANALYTICS=true
